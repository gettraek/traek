# Server-side only. Required for the demo app (/demo) to stream from OpenAI.
# Copy to .env and set your key: cp .env.example .env
OPENAI_API_KEY=sk-...

# Optional: daily rate limit per IP for /api/chat (default 50). Set to empty to use default.
# CHAT_DAILY_LIMIT_PER_IP=50

# --- Reverse proxy / client IP detection (adapter-node) ---
# Per-IP rate limiting uses getClientAddress(), which by default returns the socket
# address. Behind a reverse proxy (nginx, Caddy, a load balancer, ...) that would be
# the proxy's IP, so all users would share one rate-limit bucket.
# Set ADDRESS_HEADER to the header your proxy sets with the real client IP.
# ADDRESS_HEADER=x-forwarded-for
# When using x-forwarded-for, XFF_DEPTH must be the number of trusted proxies in
# front of the app (the rightmost XFF_DEPTH-th entry from the right is used).
# Headers are spoofable by clients unless your proxy overwrites them — only set
# these when every request actually passes through that many trusted proxies.
# XFF_DEPTH=1
