	},
	"dependencies": {
		"itty-router": "^5.0.18"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250525.0",
		"typescript": "^5.9.3",
		"wrangler": "^4.20.5"
	}
}
