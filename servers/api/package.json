{
	"name": "@traek/api",
	"version": "0.0.1",
	"description": "Cloudflare Worker — Træk Cloud Persistence API",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"deploy": "wrangler deploy",
		"build": "tsc --noEmit",
